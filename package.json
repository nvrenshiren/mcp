{
  "name": "mcp",
  "version": "0.0.0",
  "private": true,
  "description": "A monorepo of MCP (Model Context Protocol) servers for AI assistants",
  "author": "nvrenshiren <nvrenshiren@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/nvrenshiren/mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nvrenshiren/mcp.git"
  },
  "bugs": {
    "url": "https://github.com/nvrenshiren/mcp/issues"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r --filter=\"./packages/*\" run build",
    "typecheck": "pnpm -r --filter=\"./packages/*\" run typecheck",
    "test": "pnpm -r --filter=\"./packages/*\" run test",
    "clean": "pnpm -r --filter=\"./packages/*\" run clean",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/node": "^20.17.10",
    "typescript": "^5.7.2"
  }
}
